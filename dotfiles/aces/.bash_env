#!/bin/bash
# ACES env (batch-safe)
# Source from .bashrc: [ -f "$HOME/.bash_env" ] && . "$HOME/.bash_env"

# Storage layout:
#   group scratch → models, containers, repos (5TB)
#   user scratch  → caches, venvs, tmp (1TB)
export SCRATCH_USER="/scratch/user/$USER"
export SCRATCH_GROUP="/scratch/group/p.cis251377.000"
export PROJ_USER="$SCRATCH_GROUP/$USER"

mkdir -p "$PROJ_USER"/{repositories,data,checkpoints,results,logs,containers} 2>/dev/null
mkdir -p "$SCRATCH_USER"/{.cache,.tools/uv,.tools/uv/python,runs,tmp,bin,.local/bin} 2>/dev/null

# XDG
export XDG_CACHE_HOME="$SCRATCH_USER/.cache"
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_DATA_HOME="$HOME/.local/share"

# uv
export UV_CACHE_DIR="$XDG_CACHE_HOME/uv"
export UV_TOOL_DIR="$SCRATCH_USER/.tools/uv"
export UV_PYTHON_INSTALL_DIR="$SCRATCH_USER/.tools/uv/python"
export UV_INSTALL_DIR="$SCRATCH_USER/.local/bin"
export UV_LINK_MODE=copy
mkdir -p "$UV_CACHE_DIR" "$UV_TOOL_DIR" "$UV_PYTHON_INSTALL_DIR" 2>/dev/null

# ML caches (on user scratch)
export HF_HOME="$XDG_CACHE_HOME/huggingface"
export TRANSFORMERS_CACHE="$HF_HOME/transformers"
export HF_DATASETS_CACHE="$HF_HOME/datasets"
export TORCH_HOME="$XDG_CACHE_HOME/torch"
export PIP_CACHE_DIR="$XDG_CACHE_HOME/pip"
export WANDB_DIR="$XDG_CACHE_HOME/wandb"

# HF TOKEN — set your token here (do not commit real tokens)
export HF_TOKEN="hf_YOUR_TOKEN_HERE"

# Apptainer / Singularity
export APPTAINER_CACHEDIR="$XDG_CACHE_HOME/apptainer"
export SINGULARITY_CACHEDIR="$XDG_CACHE_HOME/apptainer"
mkdir -p "$APPTAINER_CACHEDIR" 2>/dev/null

# WebProxy (needed for internet on compute nodes, e.g. container pulls)
if [[ -n "${SLURM_JOB_ID:-}" ]] && command -v module >/dev/null 2>&1; then
  if [[ -z "${WEBPROXY_LOADED:-}" ]]; then
    module load WebProxy 2>/dev/null && export WEBPROXY_LOADED=1
  fi
fi

# PATH
for p in "$UV_TOOL_DIR/bin" "$SCRATCH_USER/.local/bin" "$SCRATCH_USER/bin" \
         "$HOME/.local/bin" "$HOME/bin"; do
  case ":$PATH:" in *":$p:"*) ;; *) PATH="$p:$PATH" ;; esac
done
export PATH

# GPU modules (only on GPU nodes)
if command -v nvidia-smi >/dev/null 2>&1; then
  if command -v module >/dev/null 2>&1; then
    if [[ -z "${GPU_MODTREE_LOADED:-}" ]]; then
      module load GCC/13.2.0 CUDA/12.8.0
      export GPU_MODTREE_LOADED=1
    fi
  fi
fi

# Terminal logging for SLURM jobs
if [[ -n "${SLURM_JOB_ID:-}" ]] && [[ -n "${SLURM_PTY_PORT:-}" ]]; then
  if [[ -z "${SCRIPT_RECORDING:-}" ]]; then
    NODE_KIND=$(command -v nvidia-smi >/dev/null 2>&1 && echo "gpunode" || echo "cpunode")
    LOG_DIR="$PROJ_USER/logs/terminal/$NODE_KIND/$(date +%Y%m%d)"
    mkdir -p "$LOG_DIR"
    export SCRIPT_RECORDING=1
    exec script -q -f "$LOG_DIR/terminal-$(date +%Y%m%d-%H%M%S).log"
  fi
fi
